      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb-ds"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT TO_CHAR(\"timestamp\" AT TIME ZONE 'America/Sao_Paulo', 'DD/MM/YYYY HH24:MI:SS') AS \"Data/Hora\", device_id AS \"Dispositivo\", ROUND(distancia::numeric, 2) AS \"Distância (cm)\", cancela_aberta::text AS \"Status\", localizacao AS \"Localização\" FROM eventos_cancela ORDER BY \"timestamp\" DESC LIMIT 20;",
          "refId": "A"
        }
